#!/usr/bin/env bash
set -euo pipefail

LUA_VERSION_STRING="Lua 5.2"
LUA_VERSION_MINOR="5.2"

# Resolve FACTESTIO_ROOT from this script's location
SOURCE_PATH="${BASH_SOURCE[0]:-$0}"
while [ -h "$SOURCE_PATH" ]; do
  SOURCE_DIR="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)"
  LINK_TARGET="$(readlink "$SOURCE_PATH")"
  if [[ "$LINK_TARGET" == /* ]]; then
    SOURCE_PATH="$LINK_TARGET"
  else
    SOURCE_PATH="$SOURCE_DIR/$LINK_TARGET"
  fi
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)"
FACTESTIO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
export FACTESTIO_ROOT

# Verify lua is on PATH and is Lua 5.2.x
if ! command -v lua &>/dev/null; then
  echo "Error: lua not found on PATH. Install Lua ${LUA_VERSION_MINOR}.x (e.g. via luaver, homebrew, or your package manager)." >&2
  exit 1
fi
LUA_VERSION=$(lua -e 'print(_VERSION)')
if [[ "$LUA_VERSION" != "$LUA_VERSION_STRING" ]]; then
  echo "Error: Lua ${LUA_VERSION_MINOR}.x required, but found '$LUA_VERSION'." >&2
  echo "Install Lua ${LUA_VERSION_MINOR}.x and ensure it is first on your PATH." >&2
  exit 1
fi

LUAROCKS_BIN=""
if command -v luarocks &>/dev/null; then
  LUAROCKS_BIN="$(command -v luarocks)"
fi

LUAROCKS_LUA_PATH=""
LUAROCKS_LUA_CPATH=""
if [[ -n "$LUAROCKS_BIN" ]]; then
  LUAROCKS_LUA_VERSION=$("$LUAROCKS_BIN" config lua_version 2>/dev/null | tr -d '[:space:]' || true)
  if [[ "$LUAROCKS_LUA_VERSION" == "$LUA_VERSION_MINOR" ]]; then
    LUAROCKS_LUA_PATH=$("$LUAROCKS_BIN" path --lr-path 2>/dev/null || true)
    LUAROCKS_LUA_CPATH=$("$LUAROCKS_BIN" path --lr-cpath 2>/dev/null || true)
  fi
fi

if [[ -n "$LUAROCKS_LUA_PATH" ]]; then
  LUAROCKS_LUA_PATH="${LUAROCKS_LUA_PATH};"
fi
if [[ -n "$LUAROCKS_LUA_CPATH" ]]; then
  LUAROCKS_LUA_CPATH="${LUAROCKS_LUA_CPATH};"
fi

export LUA_PATH="$FACTESTIO_ROOT/?.lua;$FACTESTIO_ROOT/?/init.lua;./?.lua;./?/init.lua;${LUAROCKS_LUA_PATH}${LUA_PATH:-}"
export LUA_CPATH="${LUAROCKS_LUA_CPATH}${LUA_CPATH:-}"

mkdir -p "$FACTESTIO_ROOT/tmp"
INTERRUPT_FILE="$FACTESTIO_ROOT/tmp/factestio.interrupt"
rm -f "$INTERRUPT_FILE"
INTERRUPT_COUNT=0
CHILD_PID=""

_factestio_cleanup() {
  local pid_file="$FACTESTIO_ROOT/tmp/factestio.pid"
  if [[ -f "$pid_file" ]]; then
    local pid
    pid=$(cat "$pid_file")
    kill -9 "$pid" 2>/dev/null
    rm -f "$pid_file"
  fi
}

_factestio_interrupt() {
  INTERRUPT_COUNT=$((INTERRUPT_COUNT + 1))
  if [[ "$INTERRUPT_COUNT" -eq 1 ]]; then
    touch "$INTERRUPT_FILE"
    printf 'Interrupt received. Waiting for the current scenario to finish; press Ctrl+C again to force stop.\n' >&2
    return
  fi

  _factestio_cleanup
  if [[ -n "$CHILD_PID" ]]; then
    kill -9 "$CHILD_PID" 2>/dev/null || true
  fi
  exit 130
}

trap '_factestio_interrupt' INT TERM

lua "$FACTESTIO_ROOT/lib/main.lua" "$@" &
CHILD_PID=$!
status=0
while true; do
  if wait "$CHILD_PID"; then
    status=0
    break
  fi
  status=$?
  if kill -0 "$CHILD_PID" 2>/dev/null; then
    continue
  fi
  break
done
rm -f "$INTERRUPT_FILE"
exit "$status"
