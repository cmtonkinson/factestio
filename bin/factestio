#!/usr/bin/env zsh
set -euo pipefail

# Resolve FACTESTIO_ROOT from this script's location
FACTESTIO_ROOT=${0:A:h}/..
export FACTESTIO_ROOT

# Verify lua is on PATH and is Lua 5.2.x
if ! command -v lua &>/dev/null; then
  echo "Error: lua not found on PATH. Install Lua 5.2.x (e.g. via luaver, homebrew, or your package manager)." >&2
  exit 1
fi
LUA_VERSION=$(lua -e 'print(_VERSION)')
if [[ "$LUA_VERSION" != "Lua 5.2" ]]; then
  echo "Error: Lua 5.2.x required, but found '$LUA_VERSION'." >&2
  echo "Install Lua 5.2.x and ensure it is first on your PATH." >&2
  exit 1
fi

LUAROCKS_LUA_PATH=""
LUAROCKS_LUA_CPATH=""
if command -v luarocks &>/dev/null; then
  LUAROCKS_LUA_PATH=$(luarocks path --lr-path 2>/dev/null || true)
  LUAROCKS_LUA_CPATH=$(luarocks path --lr-cpath 2>/dev/null || true)
fi

if [[ -n "$LUAROCKS_LUA_PATH" ]]; then
  LUAROCKS_LUA_PATH="${LUAROCKS_LUA_PATH};"
fi
if [[ -n "$LUAROCKS_LUA_CPATH" ]]; then
  LUAROCKS_LUA_CPATH="${LUAROCKS_LUA_CPATH};"
fi

export LUA_PATH="$FACTESTIO_ROOT/?.lua;$FACTESTIO_ROOT/?/init.lua;./?.lua;./?/init.lua;${LUAROCKS_LUA_PATH}${LUA_PATH:-}"
export LUA_CPATH="${LUAROCKS_LUA_CPATH}${LUA_CPATH:-}"

mkdir -p "$FACTESTIO_ROOT/tmp"

_factestio_cleanup() {
  local pid_file="$FACTESTIO_ROOT/tmp/factestio.pid"
  if [[ -f "$pid_file" ]]; then
    local pid
    pid=$(cat "$pid_file")
    kill -9 "$pid" 2>/dev/null
    rm -f "$pid_file"
  fi
}
trap '_factestio_cleanup' INT TERM

exec lua "$FACTESTIO_ROOT/run.lua" "$@"
